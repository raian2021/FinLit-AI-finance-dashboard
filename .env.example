# FinLit Configuration
# Copy to .env and fill in your values

# ── Database ──
DATABASE_URL=postgresql+asyncpg://finlit:finlit_dev@db:5432/finlit
DATABASE_URL_SYNC=postgresql://finlit:finlit_dev@db:5432/finlit

# ── API Security ──
API_KEY=change-me-to-a-random-string
SECRET_KEY=change-me-to-another-random-string

# ── AI Provider ──
# Options: claude, openai
AI_PROVIDER=claude

# Claude (default — Haiku is cheapest at ~$0.25/1M input tokens)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (fallback)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# ── App Settings ──
APP_NAME=FinLit
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# ── Compound Growth Defaults ──
DEFAULT_ANNUAL_RETURN=0.07
DEFAULT_INFLATION_RATE=0.025
